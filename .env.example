# --- Logging Configuration ---
# Recommended levels: trace, debug, info, warn, error
RUST_LOG_FILE=trace
RUST_LOG_CONSOLE=info

# --- Authentication (JWT) ---
# WARNING: JWT_SECRET must be at least 32 characters long.
JWT_SECRET=replace_this_value_with_a_secure_32_char_secret
# Token expiration time in seconds (86400 = 24 hours)
JWT_EXPIRATION_TIME=86400

# --- Security & Server Configuration ---
# Allowed URLs separated by commas
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Host and port where the API will run
HOST=127.0.0.1:8000

# --- Database Configuration ---
# PostgreSQL credentials
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=local_db

# Connection URL built from the variables above
# Format: postgres://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB>
DATABASE_URL=postgres://postgres:postgres@localhost:5432/local_db